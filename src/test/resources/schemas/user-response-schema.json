{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserResponse",
  "description": "Schema for GET /api/users/{id} response from ReqRes",
  "type": "object",
  "required": ["data", "support"],
  "properties": {
    "data": {
      "type": "object",
      "required": ["id", "email", "first_name", "last_name", "avatar"],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "first_name": {
          "type": "string",
          "minLength": 1
        },
        "last_name": {
          "type": "string",
          "minLength": 1
        },
        "avatar": {
          "type": "string",
          "pattern": "^https?://.+"
        }
      },
      "additionalProperties": false
    },
    "support": {
      "type": "object",
      "required": ["url", "text"],
      "properties": {
        "url": {
          "type": "string",
          "pattern": "^https?://.+"
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
