<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="RestAssured API Automation Suite" verbose="2" parallel="classes" thread-count="3">

    <listeners>
        <listener class-name="com.api.framework.listeners.TestNGListener"/>
    </listeners>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- AUTHENTICATION TESTS                                 -->
    <!-- ════════════════════════════════════════════════════ -->
    <test name="Authentication Tests" preserve-order="true">
        <classes>
            <class name="com.api.tests.auth.AuthTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- USER CRUD TESTS                                      -->
    <!-- ════════════════════════════════════════════════════ -->
    <test name="User GET Tests" preserve-order="true">
        <classes>
            <class name="com.api.tests.users.GetUsersTest"/>
        </classes>
    </test>

    <test name="User Create-Update-Delete Tests" preserve-order="true">
        <classes>
            <class name="com.api.tests.users.CreateUpdateDeleteUserTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- RESOURCES TESTS                                      -->
    <!-- ════════════════════════════════════════════════════ -->
    <test name="Resources Tests" preserve-order="true">
        <classes>
            <class name="com.api.tests.users.ResourcesTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- POSTS TESTS (JSONPlaceholder)                        -->
    <!-- ════════════════════════════════════════════════════ -->
    <test name="Posts CRUD Tests" preserve-order="true">
        <classes>
            <class name="com.api.tests.posts.PostsTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════ -->
    <!-- ADVANCED FEATURES TESTS                              -->
    <!-- ════════════════════════════════════════════════════ -->
    <test name="Advanced RestAssured Tests" preserve-order="true">
        <classes>
            <class name="com.api.tests.users.AdvancedRestAssuredTest"/>
        </classes>
    </test>

</suite>
